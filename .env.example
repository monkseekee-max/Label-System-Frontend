# ============================================================================
# 前端环境变量模板 (ADR-019 P0)
# 复制为 .env (本地开发) 或在 CI/生产注入对应变量.
# ============================================================================

# 后端 API 前缀
VITE_API_BASE_URL = "/api"

# 登录之后默认跳转的路由
VITE_BASE_HOME_PATH = "/home"

# 网站标题
VITE_GLOB_APP_TITLE = "智能标注系统"

# 用于设置 Zustand 存储的前缀标识，解决多项目共存时的命名冲突问题。
VITE_APP_NAMESPACE = react-antd-admin

# ----------------------------------------------------------------------------
# ADR-019 P0-1: Mock fallback 开关
# - 开发/演示: true (真实后端失败时回退 Mock, 防止白屏)
# - 生产:     必须为 false (后端故障必须显式暴露, 禁止假数据)
# 注意: 生产构建 (import.meta.env.PROD) 下, 即使误设为 true 也会被代码强制关闭.
# ----------------------------------------------------------------------------
VITE_ENABLE_MOCK_FALLBACK = true

# ----------------------------------------------------------------------------
# ADR-019 P0-4 / Phase0 P0-1: LLM Factory 直连主服务配置
# 鉴权已统一走登录态 JWT (useAuthStore), 经同源 /api 代理到后端, 后端以 JWT 鉴权.
# 下列 VITE_LLM_FACTORY_TOKEN / VITE_LLM_FACTORY_API_KEY 已废弃:
#   - 它们是 VITE_ 前缀变量, 会被打进浏览器 bundle, 任何用户可从 devtools 提取.
#   - 现在前端不再读取, 服务级密钥只应存在于服务端环境.
# 仅 VITE_LLM_FACTORY_BASE_URL 仍被使用 (默认空 → 同源 /api 代理).
# ----------------------------------------------------------------------------
# 训练任务终止 / data-productivity 使用的 Base URL (默认空: 同源 /api 代理)
# VITE_LLM_FACTORY_BASE_URL = "http://127.0.0.1:9090"
# [已废弃] 不再使用, 前端鉴权统一走登录态 JWT
# VITE_LLM_FACTORY_TOKEN = ""
# VITE_LLM_FACTORY_API_KEY = ""
