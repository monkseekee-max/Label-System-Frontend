# 后端 API 前缀
VITE_API_BASE_URL = "/api"

# 登录之后默认调转的路由
VITE_BASE_HOME_PATH = "/home"

# 网站标题
VITE_GLOB_APP_TITLE = "智能标注系统"

# ADR-019 P0: 开发/演示可启用，生产必须关闭
VITE_ENABLE_MOCK_FALLBACK = true

# 用于设置 Zustand 存储的前缀标识，解决多项目共存时的命名冲突问题。
VITE_APP_NAMESPACE=react-antd-admin

# llm-factory 主后端 X-API-Key (可选 dev 逃生通道; 默认不发, 主路径走真实登录 JWT)
# 需要时本地自行设置, 勿提交默认 dev key (ADR-019 门禁)
# VITE_LLM_FACTORY_API_KEY = ""
